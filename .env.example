# COUNSEL Environment Configuration
# Copy to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Evidence configuration
COUNSEL_EVIDENCE_ROOT=/mnt/evidence
COUNSEL_RUN_ID=                    # auto-generated if empty

# Output
COUNSEL_LEDGER_PATH=/tmp/counsel-ledger.jsonl
COUNSEL_RULES_DIR=/path/to/counsel/rules

# Forensic tool binaries (auto-detected from PATH if not set)
# COUNSEL_PECMD_BIN=/usr/share/doc/pecmd/PECmd.exe
# COUNSEL_RECMD_BIN=/usr/share/doc/recmd/RECmd.exe
# COUNSEL_AMCACHE_BIN=/usr/share/doc/amcacheparser/AmcacheParser.exe
# COUNSEL_MFTECMD_BIN=/usr/share/doc/mftecmd/MFTECmd.exe
# COUNSEL_VOL_BIN=vol3
# COUNSEL_TSHARK_BIN=tshark
# COUNSEL_YARA_BIN=yara
# COUNSEL_EVTX_DUMP_BIN=evtx_dump

# Tuning
COUNSEL_MAX_RECORDS=200
COUNSEL_MAX_STRING_LEN=512
COUNSEL_TOOL_TIMEOUT=120
COUNSEL_LOG_LEVEL=INFO
